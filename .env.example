# Supabase — 대시보드 Project Settings > API Keys 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# secret 키: RLS를 우회하므로 서버 전용. 절대 NEXT_PUBLIC_ 접두어 금지.
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx   # 푸시 발송 라우트가 push_subscriptions 조회에 사용

# ── Web Push (VAPID) ──────────────────────────────────────────────
# 키 생성: node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=B...          # 공개키 (클라이언트 구독용)
VAPID_PRIVATE_KEY=...                       # 개인키 (서버 발송용, 절대 NEXT_PUBLIC_ 금지)
VAPID_SUBJECT=mailto:you@example.com        # web-push 필수 식별자(mailto: 또는 URL)
PUSH_WEBHOOK_SECRET=long-random-string      # /api/push/send 보호용 (Supabase 웹훅 헤더와 일치)

# ── Kakao Map (구장 위치 지도) ─────────────────────────────────────
# 카카오 개발자 콘솔(카카오 OAuth와 같은 앱) > 앱 키 > JavaScript 키.
# 콘솔 > 플랫폼 > Web 에 사용 도메인 등록 필요(http://localhost:4000, https://foot-mate.vercel.app).
# 지도 타일은 도메인 화이트리스트 기반이라 secret 아님 → NEXT_PUBLIC_ 노출 OK.
NEXT_PUBLIC_KAKAO_MAP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
